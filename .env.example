# Used by load_twitch_app_config() when running main.py (including Docker Compose).
# Copy to `.env` next to docker-compose.yml or use `config/.env` if you prefer.

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional: stderr only — no files under logs/ (handy on small disks, e.g. Raspberry Pi).
# NO_LOGS=1
# TWITCH_DEBUG=1
