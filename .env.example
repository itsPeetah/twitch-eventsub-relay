# Used by load_twitch_app_config() when running main.py locally.
# Copy this file to `.env` in the repo root (optional helper); Docker Compose uses `.env.compose` instead — see env.compose.example.

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional: stderr only — no files under logs/ (handy on small disks, e.g. Raspberry Pi).
# NO_LOGS=1
# TWITCH_DEBUG=1
